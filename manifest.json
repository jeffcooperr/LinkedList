{
  "manifest_version": 3,
  "name": "LinkedList",
  "version": "1.0",
  "description": "Track LinkedIn jobs directly to your Google Sheet",
  "permissions": ["identity", "storage", "tabs", "webNavigation", "alarms"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://sheets.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://gmail.googleapis.com/*",
    "https://linkedlist-proxy.vercel.app/*"
  ],
  "oauth2": {
    "client_id": "310038408661-5lc4856ksice7v2kij2nk9sk8fs3pq41.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
