{
  "manifest_version": 3,
  "name": "LinkedIn Job Tracker",
  "version": "1.0",
  "description": "Extract job details from LinkedIn job pages",
  "permissions": ["clipboardWrite", "scripting", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*", "http://localhost:8000/*"],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/view/*",
        "https://www.linkedin.com/jobs/search/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
